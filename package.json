{
  "name": "porsche-design-system-analyzer",
  "version": "2.1.0",
  "description": "Analysiert Websites auf Porsche Design System Compliance",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "build": "node -e \"require('fs').readdirSync('.').filter(f=>/^porsche-design-system-analyzer(-v.*)?-chrome\\.zip$/.test(f)).forEach(f=>require('fs').unlinkSync(f))\" && wxt build",
    "zip": "wxt zip",
    "deploy": "wxt zip && node -e \"const v=require('./package.json').version,fs=require('fs'),g=fs.readdirSync('.').filter(f=>/^porsche-design-system-analyzer(-v.*)?-chrome\\.zip$/.test(f));g.forEach(f=>fs.unlinkSync(f));fs.copyFileSync('.output/porsche-design-system-analyzer-'+v+'-chrome.zip','./porsche-design-system-analyzer-v'+v+'-chrome.zip');const r=fs.readFileSync('README.md','utf8').replace(/porsche-design-system-analyzer-v[^)]+\\.zip/,'porsche-design-system-analyzer-v'+v+'-chrome.zip');fs.writeFileSync('README.md',r);\""
  },
  "dependencies": {
    "wxt": "^0.20.20"
  }
}
